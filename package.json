{
  "name": "ghumle-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:smoke": "playwright test tests/ghumle-smoke.spec.ts --browser=chromium",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "npm run db:generate --workspace @ghumle/api",
    "db:migrate": "npm run db:migrate --workspace @ghumle/api",
    "db:seed": "npm run db:seed --workspace @ghumle/api"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.17.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.1",
    "turbo": "^2.9.5",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "lodash": "4.18.1",
    "path-to-regexp": "8.4.2"
  }
}
