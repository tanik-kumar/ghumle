{
  "name": "ghumle-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "npm run db:generate --workspace @ghumle/api",
    "db:migrate": "npm run db:migrate --workspace @ghumle/api",
    "db:seed": "npm run db:seed --workspace @ghumle/api"
  },
  "devDependencies": {
    "@types/node": "^22.17.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.1",
    "turbo": "^2.8.21",
    "typescript": "^5.9.3"
  }
}
